{% extends 'base.html.twig' %}

{% trans_default_domain 'login' %}

{% block title %}{{ 'login.title'|trans }}{% endblock %}

{% block body %}

<div class="flex min-h-screen bg-white">

    <main class="flex w-full items-center justify-center p-4 lg:w-1/2 lg:p-8">

        <div class="w-full max-w-lg">

            <div class="mb-6 flex items-center justify-center gap-4">

                <img
                    src="{{ asset('build/images/scf.svg') }}"
                    alt="{{ 'app.logo_1'|trans }}"
                    class="h-14 w-auto"
                >

                <img
                    src="{{ asset('build/images/kitokuras.svg') }}"
                    alt="{{ 'app.logo_2'|trans }}"
                    class="h-14 w-auto"
                >

            </div>

            <div class="mb-6 text-center">

                <h1 class="text-3xl font-bold text-primary">
                    {{ 'login.title'|trans }}
                </h1>

                <p class="mt-2 text-secondary">
                    {{ 'login.subtitle'|trans }}
                </p>

            </div>

            {% set flashes = app.flashes %}

            {% if flashes is not empty %}

                <div class="mb-6 space-y-3">

                    {% for label, messages in flashes %}

                        {% for message in messages %}

                            <div
                                class="flex items-center gap-4 rounded-2xl border p-4 shadow-sm

                                {% if label == 'success' %}
                                    border-primary/30 bg-primary/10

                                {% elseif label == 'error' %}
                                    border-red-200 bg-red-50

                                {% elseif label == 'warning' %}
                                    border-amber-200 bg-amber-50

                                {% else %}
                                    border-primary bg-primary

                                {% endif %}
                            ">

                                <div
                                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full font-bold

                                    {% if label == 'success' %}
                                        bg-primary text-secondary

                                    {% elseif label == 'error' %}
                                        bg-red-100 text-red-600

                                    {% elseif label == 'warning' %}
                                        bg-amber-100 text-amber-600

                                    {% else %}
                                        bg-secondary text-white

                                    {% endif %}
                                ">

                                </div>

                                <div class="flex-1">

                                    <p
                                        class="text-sm leading-6

                                        {% if label == 'success' %}
                                            text-secondary

                                        {% elseif label == 'error' %}
                                            text-red-700

                                        {% elseif label == 'warning' %}
                                            text-amber-700

                                        {% else %}
                                            text-secondary

                                        {% endif %}
                                    ">
                                        {{ message|trans }}
                                    </p>

                                </div>

                            </div>

                        {% endfor %}

                    {% endfor %}

                </div>

            {% endif %}

            <div class="mb-6 grid grid-cols-2 gap-3">

                <a
                    href="{{ path('connect_google') }}"
                    class="group flex h-12 items-center justify-center gap-3 rounded-xl border border-state bg-white transition hover:border-primary hover:bg-primary/5"
                >

                    <img
                        src="{{ asset('build/images/Google_G_logo.svg') }}"
                        alt="Google"
                        class="h-5 w-5"
                    >

                    <span class="font-medium text-secondary transition-colors group-hover:text-primary">
                        Google
                    </span>

                </a>

                <a
                    href="{{ path('connect_line') }}"
                    class="group flex h-12 items-center justify-center gap-3 rounded-xl border border-state bg-white transition hover:border-primary hover:bg-primary/5"
                >

                    <img
                        src="{{ asset('build/images/LINE_logo.svg') }}"
                        alt="LINE"
                        class="h-5 w-5"
                    >

                    <span class="font-medium text-secondary transition-colors group-hover:text-primary">
                        LINE
                    </span>

                </a>

            </div>

            <div class="relative mb-6">

                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-state"></div>
                </div>

                <div class="relative flex justify-center">

                    <span class="bg-white px-3 text-sm text-state">
                        {{ 'login.or_continue_with'|trans }}
                    </span>

                </div>

            </div>

            <form method="post" class="space-y-4">

                <input
                    type="hidden"
                    name="_csrf_token"
                    value="{{ csrf_token('authenticate') }}"
                >

                <div>

                    <label
                        for="username"
                        class="mb-2 block text-sm font-medium text-state"
                    >
                        {{ 'login.email'|trans({}, 'forms') }}
                    </label>

                    <input
                        id="username"
                        name="_username"
                        type="email"
                        value="{{ last_username }}"
                        autocomplete="email"
                        autofocus
                        required
                        placeholder="{{ 'login.email_placeholder'|trans({}, 'forms') }}"
                        class="w-full rounded-xl border border-state bg-white px-4 py-3 text-state outline-none transition placeholder:text-state focus:border-primary focus:ring-2 focus:ring-primary"
                    >

                </div>
                                <div>

                    <label
                        for="password"
                        class="mb-2 block text-sm font-medium text-state"
                    >
                        {{ 'login.password'|trans({}, 'forms') }}
                    </label>

                    <input
                        id="password"
                        name="_password"
                        type="password"
                        autocomplete="current-password"
                        required
                        placeholder="{{ 'login.password_placeholder'|trans({}, 'forms') }}"
                        class="w-full rounded-xl border border-state bg-white px-4 py-3 text-state outline-none transition placeholder:text-state focus:border-primary focus:ring-2 focus:ring-primary"
                    >

                </div>

                <div class="flex items-center justify-between text-sm">

                    <label class="flex items-center gap-2">

                        <input
                            type="checkbox"
                            name="_remember_me"
                            class="rounded border-state text-primary focus:ring-primary"
                        >

                        <span class="text-state">
                            {{ 'login.remember_me'|trans }}
                        </span>

                    </label>

                    <a
                        href="#"
                        class="font-medium text-secondary transition-colors hover:text-primary hover:underline"
                    >
                        {{ 'login.forgot_password'|trans }}
                    </a>

                </div>

                <button
                    type="submit"
                    class="w-full rounded-xl bg-secondary py-3 font-semibold text-white transition duration-200 hover:-translate-y-0.5 hover:bg-secondary/90 hover:shadow-lg"
                >
                    {{ 'login.submit'|trans }}
                </button>

            </form>

            <div class="mt-8 text-center text-sm text-state">

                {{ 'login.no_account'|trans }}

                <a
                    href="{{ path('app_register') }}"
                    class="ml-1 font-semibold text-secondary transition-colors hover:text-primary hover:underline"
                >
                    {{ 'login.create_account'|trans }}
                </a>

            </div>

        </div>

    </main>

    <aside class="hidden lg:block lg:w-1/2">

        <img
            src="{{ asset('build/images/loginBG.png') }}"
            alt=""
            class="h-screen w-full object-cover"
        >

    </aside>

</div>

{% endblock %}