{# templates/account/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ 'account.dashboard.title'|trans }}{% endblock %}

{% block body %}
    <div class="min-h-screen bg-slate-50 text-slate-900">
        <a href="#main-content"
           class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-xl focus:bg-white focus:px-4 focus:py-2">
            Skip to content
        </a>

        <nav class="sticky top-0 z-50 border-b border-slate-200 bg-white">
            <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8">
                <div class="flex min-w-0 items-center gap-3">
                    <a href="{{ path('app_home') }}"
                       class="flex shrink-0 items-center justify-center rounded-2xl bg-white p-2">
                        <img
                            src="{{ asset('build/images/scf.svg') }}"
                            alt="SCF"
                            class="h-10 w-auto"
                        >
                    </a>

                    <div class="min-w-0">
                        <p class="hidden text-xs font-medium uppercase tracking-[0.2em] text-state sm:block">
                            {{ 'account.dashboard.space'|trans }}
                        </p>
                        <h1 class="truncate text-sm font-semibold text-secondary sm:text-lg">
                            {{ app.user.name }} {{ app.user.lastname }}
                        </h1>
                    </div>
                </div>

                <div class="flex items-center gap-2 sm:gap-3">
                    <a href="{{ path('app_home') }}"
                       class="inline-flex min-h-11 items-center justify-center rounded-xl bg-primary px-3 py-2 text-sm font-semibold text-secondary transition hover:bg-primary-hover sm:px-4">
                        <span class="hidden sm:inline">{{ 'account.dashboard.new_booking'|trans }}</span>
                        <span class="sm:hidden">+</span>
                    </a>

                    <div class="hidden items-center gap-1 rounded-2xl border border-secondary/10 bg-secondary/5 p-1 sm:flex">
                        <a href="{{ path('app_switch_locale', {'locale': 'fr'}) }}"
                           class="inline-flex min-h-10 items-center justify-center rounded-xl px-3 py-2 text-sm font-medium transition {{ app.request.locale == 'fr' ? 'bg-secondary text-white' : 'text-secondary hover:bg-white' }}">
                            FR
                        </a>

                        <a href="{{ path('app_switch_locale', {'locale': 'en'}) }}"
                           class="inline-flex min-h-10 items-center justify-center rounded-xl px-3 py-2 text-sm font-medium transition {{ app.request.locale == 'en' ? 'bg-secondary text-white' : 'text-secondary hover:bg-white' }}">
                            EN
                        </a>

                        <a href="{{ path('app_switch_locale', {'locale': 'jp'}) }}"
                           class="inline-flex min-h-10 items-center justify-center rounded-xl px-3 py-2 text-sm font-medium transition {{ app.request.locale == 'jp' ? 'bg-secondary text-white' : 'text-secondary hover:bg-white' }}">
                            JP
                        </a>
                    </div>

                    <details class="relative">
                        <summary class="flex min-h-11 cursor-pointer list-none items-center gap-3 rounded-2xl border border-[#dcc3a5] bg-[#f3e7d7] px-3 py-2 text-sm text-[#7a4b2a] transition hover:bg-[#eddcc7]">
                            <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-[#e2c6a1] text-[#7a4b2a]">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15.75 6.75a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.5 20.118a7.5 7.5 0 0115 0A17.933 17.933 0 0112 21.75a17.933 17.933 0 01-7.5-1.632z" />
                                </svg>
                            </div>

                            <div class="hidden min-w-0 text-left sm:block">
                                <p class="truncate text-sm font-semibold leading-none text-secondary">
                                    {{ app.user.name }}
                                </p>
                                <p class="truncate text-xs text-[#7a4b2a]">
                                    {{ 'account.dashboard.my_account'|trans }}
                                </p>
                            </div>

                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-[#7a4b2a]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 9l-7 7-7-7" />
                            </svg>
                        </summary>

                        <div class="absolute right-0 mt-2 w-64 overflow-hidden rounded-2xl border border-[#dcc3a5] bg-white">
                            <div class="border-b border-[#ead8c2] bg-[#fbf5ed] px-4 py-3">
                                <p class="truncate text-sm font-semibold text-secondary">
                                    {{ app.user.name }} {{ app.user.lastname }}
                                </p>
                                <p class="truncate text-xs text-state">
                                    {{ app.user.email }}
                                </p>
                            </div>

                            <div class="flex flex-col p-2">
                                <a href="{{ path('app_home') }}"
                                   class="inline-flex min-h-11 items-center rounded-xl px-3 py-2 text-sm font-medium text-secondary transition hover:bg-[#f8efe4]">
                                    {{ 'account.dashboard.my_info'|trans }}
                                </a>

                                <a href="{{ path('app_home') }}"
                                   class="inline-flex min-h-11 items-center rounded-xl px-3 py-2 text-sm font-medium text-secondary transition hover:bg-[#f8efe4]">
                                    {{ 'account.dashboard.change_password'|trans }}
                                </a>

                                <div class="my-1 border-t border-slate-100"></div>

                                <a href="{{ path('app_home') }}"
                                   class="inline-flex min-h-11 items-center rounded-xl px-3 py-2 text-sm font-medium text-danger transition hover:bg-red-50">
                                    {{ 'account.dashboard.logout'|trans }}
                                </a>
                            </div>

                            <div class="border-t border-slate-100 p-2 sm:hidden">
                                <div class="grid grid-cols-3 gap-2">
                                    <a href="{{ path('app_switch_locale', {'locale': 'fr'}) }}"
                                       class="inline-flex min-h-10 items-center justify-center rounded-xl px-3 py-2 text-xs font-medium transition {{ app.request.locale == 'fr' ? 'bg-secondary text-white' : 'bg-secondary/5 text-secondary hover:bg-secondary/10' }}">
                                        FR
                                    </a>

                                    <a href="{{ path('app_switch_locale', {'locale': 'en'}) }}"
                                       class="inline-flex min-h-10 items-center justify-center rounded-xl px-3 py-2 text-xs font-medium transition {{ app.request.locale == 'en' ? 'bg-secondary text-white' : 'bg-secondary/5 text-secondary hover:bg-secondary/10' }}">
                                        EN
                                    </a>

                                    <a href="{{ path('app_switch_locale', {'locale': 'jp'}) }}"
                                       class="inline-flex min-h-10 items-center justify-center rounded-xl px-3 py-2 text-xs font-medium transition {{ app.request.locale == 'jp' ? 'bg-secondary text-white' : 'bg-secondary/5 text-secondary hover:bg-secondary/10' }}">
                                        JP
                                    </a>
                                </div>
                            </div>
                        </div>
                    </details>
                </div>
            </div>

            <div class="h-1 w-full bg-secondary"></div>
        </nav>

        <main id="main-content" class="mx-auto flex max-w-7xl flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
            <section class="rounded-[1.75rem] bg-white ring-1 ring-slate-200/70">
                <div class="flex flex-col gap-3 border-b border-slate-200 px-5 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-6">
                    <div>
                        <h2 class="text-lg font-semibold text-secondary">
                            {{ 'account.dashboard.booking_list'|trans }}
                        </h2>
                        <p class="mt-1 text-sm text-state">
                            {{ 'account.dashboard.booking_list_subtitle'|trans }}
                        </p>
                    </div>

                    <a href="{{ path('app_home') }}"
                       class="inline-flex min-h-11 items-center justify-center rounded-xl bg-secondary px-4 py-2 text-sm font-medium text-white transition hover:bg-secondary/90">
                        {{ 'account.dashboard.book_now'|trans }}
                    </a>
                </div>

                {% if bookings is empty %}
                    <div class="flex flex-col items-center justify-center px-6 py-16 text-center">
                        <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-secondary/5 text-secondary">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M8 7V3m8 4V3m-9 8h10m-12 9h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v11a2 2 0 002 2z" />
                            </svg>
                        </div>

                        <h3 class="mt-5 text-lg font-semibold text-secondary">
                            {{ 'account.dashboard.no_booking_title'|trans }}
                        </h3>
                        <p class="mt-2 max-w-md text-sm text-state">
                            {{ 'account.dashboard.no_booking_text'|trans }}
                        </p>

                        <a href="{{ path('app_home') }}"
                           class="mt-6 inline-flex min-h-11 items-center justify-center rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-secondary transition hover:bg-primary-hover">
                            {{ 'account.dashboard.new_booking'|trans }}
                        </a>
                    </div>
                {% else %}
                    <div class="flex flex-col divide-y divide-slate-200">
                        {% for booking in bookings %}
                            <article class="px-5 py-5 sm:px-6">
                                <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
                                    <div class="min-w-0 flex-1">
                                        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                                            <div class="min-w-0">
                                                <div class="flex flex-wrap items-center gap-2">
                                                    <h3 class="text-base font-semibold text-secondary sm:text-lg">
                                                        {{ booking.location.name ?? ('account.dashboard.location_unavailable'|trans) }}
                                                    </h3>

                                                    {% set statusClasses = {
                                                        'PENDING': 'bg-amber-100 text-amber-800',
                                                        'CONFIRMED': 'bg-green-100 text-green-800',
                                                        'CANCELLED': 'bg-rose-100 text-rose-800',
                                                        'COMPLETED': 'bg-blue-100 text-blue-800'
                                                    } %}

                                                    <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold {{ statusClasses[booking.bookingStatus.value] ?? 'bg-slate-100 text-slate-700' }}">
                                                        {{ ('booking.status.' ~ booking.bookingStatus.value)|trans }}
                                                    </span>

                                                    <span class="inline-flex items-center rounded-full bg-primary/15 px-3 py-1 text-xs font-semibold text-secondary">
                                                        {{ booking.guestCount }} {{ 'account.dashboard.guests'|trans }}
                                                    </span>
                                                </div>

                                                <p class="mt-2 text-sm text-state">
                                                    {{ 'account.dashboard.booking'|trans }} #{{ booking.id }}
                                                </p>

                                                <div class="mt-4 rounded-2xl border border-secondary/10 bg-secondary/5 px-4 py-3">
                                                    <p class="text-xs font-medium uppercase tracking-wide text-state">
                                                        {{ 'account.dashboard.stay_period'|trans }}
                                                    </p>
                                                    <p class="mt-1 text-sm font-semibold text-secondary sm:text-base">
                                                        {{ 'account.dashboard.from'|trans }}
                                                        {{ booking.startDate ? booking.startDate|date('d/m/Y H:i') : '-' }}
                                                        <span class="mx-2 text-state">→</span>
                                                        {{ 'account.dashboard.to'|trans }}
                                                        {{ booking.endDate ? booking.endDate|date('d/m/Y H:i') : '-' }}
                                                    </p>
                                                </div>

                                                <div class="mt-4 flex flex-wrap items-center gap-2">
                                                    <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-secondary">
                                                        {{ booking.isFullDay ? 'account.dashboard.full_day'|trans : 'account.dashboard.partial_day'|trans }}
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="flex shrink-0 flex-col gap-4 lg:items-end">
                                        <div class="rounded-2xl bg-[#fbf5ed] px-4 py-3 text-left lg:min-w-[170px] lg:text-right">
                                            <p class="text-xs font-medium uppercase tracking-wide text-[#7a4b2a]">
                                                {{ 'account.dashboard.price'|trans }}
                                            </p>
                                            <p class="mt-1 text-2xl font-bold leading-none text-secondary sm:text-3xl">
                                                ¥{{ booking.price|number_format(0, '.', ',') }}
                                            </p>
                                        </div>

                                        <a href="{{ path('app_home', {'id': booking.id}) }}"
                                           class="inline-flex min-h-11 items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-secondary transition hover:bg-slate-100">
                                            {{ 'account.dashboard.view_details'|trans }}
                                        </a>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                {% endif %}
            </section>
        </main>
    </div>
{% endblock %}